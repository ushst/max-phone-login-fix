{
  "manifest_version": 3,
  "name": "Вход по номеру для MAX (неофициально)",
  "version": "1.0.0",
  "description": "Неофициальное расширение: показывает кнопку «Войти по номеру телефона» на web.max.ru, если её перекрывает QR-код. Данные не собирает.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Вход по номеру для MAX"
  },
  "content_scripts": [
    {
      "matches": ["https://web.max.ru/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
